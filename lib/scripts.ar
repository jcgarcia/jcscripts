#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    createawsaccount
# Description:    Creates new AWS accounts in an organization and monitors the
#                 creation process until completion.
# Usage:          createawsaccount [options]
# Options:        -h | --help        Show this help message
#                 -v | --version     Show script version
#                 -r | --role        Organization role (default: OrganizationAccountAccessRole)
#                 -p | --profile     Management account profile (default: Foreman)
#                 -a | --account     Account details in the format: <project>:<env>:<email>
# Author:         Julio Cesar Garcia
# Date:           20/03/2025
# Version:        2.1
# ------------------------------------------------------------------------------

set -e  # Exit immediately on any error

# Default values
ORG_ROLE="OrganizationAccountAccessRole"
MANAGEMENT_PROFILE="Foreman"
LOG_FILE="createawsaccount.log"

# Display usage information
show_help() {
  echo "Usage: createawsaccount [options]"
  echo "Options:"
  echo "  -h | --help        Show this help message"
  echo "  -v | --version     Show script version"
  echo "  -r | --role        Organization role (default: $ORG_ROLE)"
  echo "  -p | --profile     Management account profile (default: $MANAGEMENT_PROFILE)"
  echo "  -a | --account     Account details in the format: <project>:<env>:<email>"
  echo
  echo "Example:"
  echo "  createawsaccount -a FinTech:dev:dev@example.com -a FinTech:prod:prod@example.com"
}

# Display script version
show_version() {
  echo "createawsaccount version 2.1"
}

# Function to handle errors
handle_error() {
  local exit_code=$1
  local message=$2
  echo "Error: $message (Exit Code: $exit_code)"
  exit $exit_code
}

# Function to validate the AWS session
validate_session() {
  local profile="$1"

  if [[ -z "$profile" ]]; then
    handle_error 1 "AWS profile is not provided. Please specify a profile."
  fi

  # Check if AWS CLI is installed
  if ! command -v aws &> /dev/null; then
    handle_error 1 "AWS CLI is not installed. Please install it and try again."
  fi

  # Validate the AWS CLI profile
  if ! aws sts get-caller-identity --profile "$profile" > /dev/null 2>&1; then
    handle_error 1 "AWS CLI session is not valid or the profile is misconfigured: $profile."
    echo "Please log in using 'aws sso login --profile $profile' and try again."
    exit 1
  fi
}

# Create a single AWS account
create_account() {
  local profile="$1"
  local project="$2"
  local env="$3"
  local email="$4"
  local account_name="${project}-${env}"

  echo "[$(date)] Creating AWS account: $account_name..." | tee -a "$LOG_FILE"

  local account_id
  account_id=$(aws organizations create-account \
    --email "$email" \
    --account-name "$account_name" \
    --role-name "$ORG_ROLE" \
    --query 'CreateAccountStatus.Id' \
    --output text \
    --profile "$profile")

  echo "[$(date)] Waiting for account creation to complete..." | tee -a "$LOG_FILE"
  while true; do
    local status
    status=$(aws organizations describe-create-account-status \
      --create-account-request-id "$account_id" \
      --query 'CreateAccountStatus.State' \
      --output text \
      --profile "$profile")

    if [[ "$status" == "SUCCEEDED" ]]; then
      local new_account_id
      new_account_id=$(aws organizations describe-create-account-status \
        --create-account-request-id "$account_id" \
        --query 'CreateAccountStatus.AccountId' \
        --output text \
        --profile "$profile")
      echo "[$(date)] Account created successfully: $new_account_id" | tee -a "$LOG_FILE"
      echo "$new_account_id" > "${account_name}_id.txt"
      break
    elif [[ "$status" == "FAILED" ]]; then
      echo "[$(date)] ERROR: Account creation failed. Check AWS Console for details." | tee -a "$LOG_FILE"
      exit 1
    fi
    echo "[$(date)] Waiting... (Current status: $status)" | tee -a "$LOG_FILE"
    sleep 10
  done

  echo "[$(date)] $env account for $project created: $new_account_id" | tee -a "$LOG_FILE"
}

# Main script logic
main() {
  # Parse command-line arguments
  local accounts=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -v|--version)
        show_version
        exit 0
        ;;
      -r|--role)
        ORG_ROLE="$2"
        shift 2
        ;;
      -p|--profile)
        MANAGEMENT_PROFILE="$2"
        shift 2
        ;;
      -a|--account)
        accounts+=("$2")
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
    esac
  done

  # Validate AWS session
  validate_session "$MANAGEMENT_PROFILE"

  # Validate input parameters
  if [[ ${#accounts[@]} -eq 0 ]]; then
    handle_error 1 "No accounts specified. Use the -a option to provide account details."
  fi

  # Process each account
  for account in "${accounts[@]}"; do
    IFS=":" read -r project env email <<< "$account"
    if [[ -z "$project" || -z "$env" || -z "$email" ]]; then
      echo "ERROR: Invalid account format: $account"
      echo "Expected format: <project>:<env>:<email>"
      exit 1
    fi
    create_account "$MANAGEMENT_PROFILE" "$project" "$env" "$email"
  done
}

# Execute the main function
main "$@"

