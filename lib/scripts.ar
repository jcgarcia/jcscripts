#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    publish
# Description:    Script with command-line options to create or push the
#                 distribution to GitHub and provide a help screen.
# Usage:          publish [-c|--create] [-p|--push] [-h|--help]
# Options:        -c | --create: Create the distribution
#                 -p | --push: Push the distribution to GitHub
#                 -h | --help: Display the help screen
# Author:         Julio Cesar Garcia
# Date:           20/03/2025
# Version:        5.5
# ------------------------------------------------------------------------------

# Default configuration content for fallback
DEFAULT_CONFIG='
# Configuration for scripts
EDITOR="vi"
SCRIPTS_DIR="~/scripts"
GITHUB_REPO="git@github.com:jcgarcia/jcscripts.git"
SSH_KEY="~/.ssh/defaultkey.pem"
'

# Load configuration from $HOME/.jcscripts or ~/scripts/.jcscripts
CONFIG_FILE="$HOME/.jcscripts"
if [[ -f "$CONFIG_FILE" ]]; then
  echo "Using configuration from $CONFIG_FILE."
  source "$CONFIG_FILE"
elif [[ -f "$HOME/scripts/.jcscripts" ]]; then
  CONFIG_FILE="$HOME/scripts/.jcscripts"
  echo "Using configuration from $CONFIG_FILE."
  source "$CONFIG_FILE"
else
  echo "Configuration file not found in $HOME or $HOME/scripts. Using default values."
  SCRIPTS_DIR="$HOME/scripts"
  SSH_KEY="$HOME/.ssh/defaultkey.pem"
  GITHUB_REPO="git@github.com:jcgarcia/jcscripts.git"
  EDITOR="vi"
fi

# Expand ~ to $HOME in paths
SCRIPTS_DIR="${SCRIPTS_DIR/#\~/$HOME}"
SSH_KEY="${SSH_KEY/#\~/$HOME}"

# Validate required configurations
validate_configurations() {
  if [[ -z "$SSH_KEY" ]]; then
    echo "ERROR: Missing SSH key. Please ensure it is configured in $CONFIG_FILE or provide it in the defaults."
    exit 1
  fi
  if [[ -z "$GITHUB_REPO" ]]; then
    echo "ERROR: Missing GitHub repository URL. Please ensure it is configured in $CONFIG_FILE or provide it in the defaults."
    exit 1
  fi
  if [[ ! -d "$SCRIPTS_DIR" ]]; then
    echo "ERROR: Scripts directory ($SCRIPTS_DIR) does not exist. Please ensure it is configured in $CONFIG_FILE or provide a valid path."
    exit 1
  fi
}

# Display help screen
display_help() {
  echo "Usage: publish [options]"
  echo "Options:"
  echo "  -c | --create   Create the distribution package"
  echo "  -p | --push     Push the distribution to GitHub"
  echo "  -h | --help     Display this help screen"
  echo
}

# Locate and copy core files to the distribution directory
copy_core_files() {
  echo "Copying core files..."

  local files=("README.md" "README.pdf" "installscripts")
  for file in "${files[@]}"; do
    if [[ -f "$file" ]]; then
      cp "$file" "$DIST_DIR/" || echo "WARNING: Failed to copy $file."
    elif [[ -f "$SCRIPTS_DIR/$file" ]]; then
      cp "$SCRIPTS_DIR/$file" "$DIST_DIR/" || echo "WARNING: Failed to copy $SCRIPTS_DIR/$file."
    else
      echo "WARNING: $file not found in the current directory or $SCRIPTS_DIR."
    fi
  done
}

# Prepare the distribution structure
prepare_structure() {
  echo "Preparing distribution structure..."

  # Define the distribution directory
  DIST_DIR="./dist"

  # Clean up previous distribution if it exists
  if [[ -d "$DIST_DIR" ]]; then
    echo "Removing existing distribution directory..."
    rm -rf "$DIST_DIR"
  fi

  # Create necessary folders
  mkdir -p "$DIST_DIR/lib"

  # Copy core files
  copy_core_files

  # Add default configuration
  echo "$DEFAULT_CONFIG" > "$DIST_DIR/.jcscripts"

  echo "Distribution structure prepared."
}

# Archive valid scripts into scripts.ar
archive_scripts() {
  echo "Archiving valid scripts into library..."

  # Check if scripts directory is valid
  if [[ ! -d "$SCRIPTS_DIR" ]]; then
    echo "ERROR: Scripts directory ($SCRIPTS_DIR) is invalid. Cannot create scripts library."
    return
  fi

  local archive_path="./dist/lib/scripts.ar"

  # Loop through files in the scripts directory
  for script in "$SCRIPTS_DIR"/*; do
    if [[ -f "$script" && -x "$script" && "$script" == "${script%.*}" ]]; then
      echo "Adding $script to $archive_path"
      ar rcs "$archive_path" "$script"
    else
      echo "Skipping invalid or non-executable file: $script"
    fi
  done

  echo "Valid scripts archived into $archive_path."
}

# Push the distribution to GitHub
push_distribution() {
  echo "Starting push process to GitHub..."

  DIST_DIR="./dist"
  if [[ ! -d "$DIST_DIR" ]]; then
    echo "ERROR: Distribution directory does not exist. Please create the distribution first using the '-c' option."
    exit 1
  fi

  cd "$DIST_DIR" || exit 1

  # Initialize and prepare Git
  git init --initial-branch=main
  git remote add origin "$GITHUB_REPO" || true
  git add .
  git commit -m "Publishing scripts distribution" || echo "Nothing to commit, all changes are up to date."

  # Force push to replace the remote repository contents
  echo "Force-pushing to GitHub..."
  GIT_SSH_COMMAND="ssh -i $SSH_KEY" git push origin main --force || {
    echo "ERROR: Push failed. Please check your GitHub configuration."
    exit 1
  }

  echo "Distribution pushed to GitHub successfully."
}

# Main function to parse options
main() {
  case "$1" in
    -c|--create)
      validate_configurations
      prepare_structure
      archive_scripts
      ;;
    -p|--push)
      validate_configurations
      push_distribution
      ;;
    -h|--help)
      display_help
      ;;
    *)
      echo "Invalid option. Use '-h' or '--help' for usage information."
      exit 1
      ;;
  esac
}

# Execute the main function with the provided option
main "$@"

scripts/        0           0     0     644     2634      `
#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    scripts
# Description:    Lists all valid scripts in the configured scripts directory
#                 (ignoring files with extensions). Extracts the header information
#                 (Script Name, Description, Usage, etc.) or outputs just the
#                 script names in columns with the -s|--short option.
# Usage:          scripts [-s|--short]
# Author:         Julio Cesar Garcia
# Date:           20/03/2025
# Version:        3.5
# ------------------------------------------------------------------------------

# Load the configuration file from the home directory or use defaults
CONFIG_FILE="$HOME/.jcscripts"
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"
  # Expand ~ to $HOME in SCRIPTS_DIR if needed
  SCRIPTS_DIR="${SCRIPTS_DIR/#\~/$HOME}"
  EDITOR="${EDITOR:-vi}" # Ensure EDITOR has a fallback
else
  echo "Configuration file not found. Using default values."
  SCRIPTS_DIR="$HOME/scripts"
  EDITOR="vi"
fi

# Function to extract and display header information
extract_header() {
  local script="$1"
  echo "$(basename "$script")"
  echo "--------------------------------------"

  # Extract labeled header fields and skip invalid placeholders
  grep -E "^(# *(Script Name|Description|Usage|Author|Date|Version):)" "$script" \
    | sed -e 's/^# *//' \
          -e '/\$script_name/d' \
          -e '/\$LOGNAME/d' \
          -e '/\$(date/d'

  echo
}

# Function to list script names in columns
list_short() {
  local scripts="$1"

  # Extract only the script names, ensuring single arguments per basename
  for script in $scripts; do
    basename "$script"
  done | column
}

# Main function
main() {
  # Check if the scripts directory exists
  if [[ ! -d "$SCRIPTS_DIR" ]]; then
    echo "ERROR: Directory $SCRIPTS_DIR does not exist."
    exit 1
  fi

  # Debugging output to confirm the directory being scanned
  echo "Scanning scripts in: $SCRIPTS_DIR"

  # Use find to only target files in the specified directory (top-level only)
  local scripts
  scripts=$(find "$SCRIPTS_DIR" -maxdepth 1 -type f ! -name "*.*" -exec file {} + | grep "ASCII text executable" | cut -d: -f1)

  if [[ -z "$scripts" ]]; then
    echo "No valid scripts found in $SCRIPTS_DIR."
    exit 0
  fi

  # Check for the -s or --short option
  if [[ "$1" == "-s" || "$1" == "--short" ]]; then
    list_short "$scripts"
    exit 0
  fi

  # Default: Display detailed header information for each script
  for script in $scripts; do
    extract_header "$script"
  done
}

# Execute the main function
main "$@"
