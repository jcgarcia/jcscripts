#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    createOrganization
# Description:    Creates AWS Organizational Units and manages their structure.
# Usage:          createOrganization [-h|--help] [-v|--version] [-p|--profile] [-r|--region]
# Options:        -h | --help       Show this help message
#                 -v | --version    Show script version
#                 -p | --profile    AWS CLI profile to use
#                 -r | --region     AWS region (default: us-east-1)
# Author:         Julio Cesar Garcia
# Date:           20/03/2025
# Version:        1.2
# ------------------------------------------------------------------------------

set -e  # Exit immediately if a command exits with a non-zero status

# Default values
AWS_REGION="us-east-1"
LOG_FILE="createOrganization.log"

# Display usage information
show_help() {
  echo "Usage: createOrganization [options]"
  echo "Options:"
  echo "  -h | --help       Show this help message"
  echo "  -v | --version    Show script version"
  echo "  -p | --profile    AWS CLI profile to use"
  echo "  -r | --region     AWS region (default: $AWS_REGION)"
  echo
  echo "Example:"
  echo "  createOrganization -p MyProfile -r us-west-2"
}

# Display script version
show_version() {
  echo "createOrganization version 1.2"
}

# Error handling function
handle_error() {
  local exit_code=$1
  local message=$2
  echo "Error: $message (Exit Code: $exit_code)"
  exit $exit_code
}

# Function to validate the AWS session
validate_session() {
  local profile="$1"

  if [[ -z "$profile" ]]; then
    handle_error 1 "AWS profile is not provided. Please specify a profile."
  fi

  # Check if AWS CLI is installed
  if ! command -v aws &> /dev/null; then
    handle_error 1 "AWS CLI is not installed. Please install it and try again."
  fi

  # Validate the AWS CLI profile
  if ! aws sts get-caller-identity --profile "$profile" > /dev/null 2>&1; then
    handle_error 1 "AWS CLI session is not valid or the profile is misconfigured: $profile."
    echo "Please log in using 'aws sso login --profile $profile' and try again."
    exit 1
  fi
}

# Function to create Organizational Units (OUs)
create_ou() {
  local profile="$1"
  local parent_id="$2"
  local ou_name="$3"

  echo "Creating Organizational Unit: $ou_name under parent ID: $parent_id..."
  ou_id=$(aws organizations create-organizational-unit \
    --profile "$profile" \
    --parent-id "$parent_id" \
    --name "$ou_name" \
    --query "OrganizationalUnit.Id" --output text)
  
  if [[ -n "$ou_id" ]]; then
    echo "Organizational Unit '$ou_name' created successfully (ID: $ou_id)"
  else
    handle_error 1 "Failed to create Organizational Unit: $ou_name."
  fi
}

# Main function
main() {
  # Parse command-line arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -v|--version)
        show_version
        exit 0
        ;;
      -p|--profile)
        AWS_PROFILE="$2"
        shift 2
        ;;
      -r|--region)
        AWS_REGION="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
    esac
  done

  # Validate required parameters
  if [[ -z "$AWS_PROFILE" ]]; then
    handle_error 1 "AWS CLI profile is required. Use the -p option."
  fi

  # Validate AWS session
  validate_session "$AWS_PROFILE"

  # Retrieve Root ID
  echo "Fetching root ID for the AWS Organization..."
  ROOT_ID=$(aws organizations list-roots \
    --query "Roots[0].Id" \
    --output text \
    --region "$AWS_REGION" \
    --profile "$AWS_PROFILE")

  if [[ -z "$ROOT_ID" ]]; then
    handle_error 1 "Failed to retrieve the root ID of the organization."
  fi
  echo "Root ID: $ROOT_ID"

  # Example: Create Organizational Units under the Root
  create_ou "$AWS_PROFILE" "$ROOT_ID" "Engineering"
  create_ou "$AWS_PROFILE" "$ROOT_ID" "Finance"
  create_ou "$AWS_PROFILE" "$ROOT_ID" "HR"

  echo "Organizational structure successfully created!"
}

# Execute the main function
main "$@"

