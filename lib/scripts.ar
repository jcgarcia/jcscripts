#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    awsorg
# Description:    Fetch and display AWS Organization layout in multiple formats.
# Usage:          awsorg.sh [-h|--help] [-v|--version] [-f|--format FORMAT]
# Options:        -h | --help    Show this help message
#                 -v | --version Show script version
#                 -f | --format  Specify the output format (json, table, text, tree)
# Author:         Julio Cesar Garcia
# Date:           15/03/2025
# Version:        3.1
# ------------------------------------------------------------------------------

# Display usage information
show_help() {
  echo "Usage: ./awsorg.sh [options]"
  echo "Options:"
  echo "  -h | --help    Show this help message"
  echo "  -v | --version Show script version"
  echo "  -f | --format  Specify the output format (json, table, text, tree)"
}

# Display script version
show_version() {
  echo "awsorg.sh version 3.1"
}

# Error handling function
handle_error() {
  local exit_code=$1
  local message=$2
  echo "Error: $message (Exit Code: $exit_code)"
  exit $exit_code
}

# Function to validate the AWS session
validate_session() {
  local profile="$1"
  
  if [[ -z "$profile" ]]; then
    handle_error 1 "AWS profile is not provided. Please specify a profile."
  fi

  # Check if AWS CLI is installed
  if ! command -v aws &> /dev/null; then
    handle_error 1 "AWS CLI is not installed. Please install it and try again."
  fi

  # Validate the AWS CLI profile
  if ! aws sts get-caller-identity --profile "$profile" > /dev/null 2>&1; then
    handle_error 1 "AWS CLI session is not valid or the profile is misconfigured: $profile."
    echo "Please log in using 'aws sso login --profile $profile' and try again."
    exit 1
  fi
}

# Cleanup function to handle temporary files
cleanup() {
  echo "Cleaning up temporary files..."
}
trap cleanup EXIT

# Recursive function to fetch and display organizational units and accounts
fetch_tree_structure() {
  local parent_id="$1"
  local indent="$2"
  local profile="$3"

  # Fetch child OUs for the parent
  ous=$(aws organizations list-organizational-units-for-parent --parent-id "$parent_id" --query "OrganizationalUnits" --output json --profile "$profile" 2> /dev/null)
  if [ $? -ne 0 ]; then
    handle_error 1 "Failed to fetch organizational units for parent ID $parent_id."
  fi

  echo "$ous" | jq -c '.[]' | while read -r ou; do
    ou_id=$(echo "$ou" | jq -r '.Id')
    ou_name=$(echo "$ou" | jq -r '.Name')
    echo "${indent}OU: $ou_name (ID: $ou_id)"

    # Fetch accounts within the current OU
    accounts=$(aws organizations list-accounts-for-parent --parent-id "$ou_id" --query "Accounts" --output json --profile "$profile" 2> /dev/null)
    if [ $? -ne 0 ]; then
      handle_error 1 "Failed to fetch accounts for OU ID $ou_id."
    fi

    echo "$accounts" | jq -c '.[]' | while read -r account; do
      account_id=$(echo "$account" | jq -r '.Id')
      account_name=$(echo "$account" | jq -r '.Name')
      echo "${indent}  Account: $account_name (ID: $account_id)"
    done

    # Recursive call to fetch sub-OUs
    fetch_tree_structure "$ou_id" "  $indent" "$profile"
  done
}

# Function to fetch and display organization details in the selected format
get_organization() {
  local format="${1:-json}" # Default to JSON format if none provided
  local profile="$2"        # AWS CLI profile

  # Validate format input
  case "$format" in
    json|table|text|tree)
      ;;
    *)
      handle_error 1 "Invalid format: $format. Allowed values are json, table, text, or tree."
      ;;
  esac

  validate_session "$profile"

  echo "Fetching AWS Organization information in '$format' format..."

  if [ "$format" == "tree" ]; then
    # Tree format output
    echo "Fetching root ID..."
    root_id=$(aws organizations list-roots --query "Roots[0].Id" --output text --profile "$profile" 2> /dev/null)
    if [ $? -ne 0 ]; then
      handle_error 1 "Failed to fetch root ID. Please check your permissions."
    fi

    echo "Root: (ID: $root_id)"
    fetch_tree_structure "$root_id" "  " "$profile"
  else
    # Standard AWS CLI-supported formats
    echo "Fetching organization details..."
    organization_info=$(aws organizations describe-organization --output "$format" --profile "$profile" 2> /dev/null)
    if [ $? -ne 0 ]; then
      handle_error 1 "Failed to fetch organization details. Please check your permissions."
    fi
    echo "Organization Details:"
    echo "$organization_info"

    echo "Fetching list of accounts..."
    accounts=$(aws organizations list-accounts --output "$format" --profile "$profile" 2> /dev/null)
    if [ $? -ne 0 ]; then
      handle_error 1 "Failed to list accounts. Please check your permissions."
    fi
    echo "Accounts:"
    echo "$accounts"

    echo "Fetching organizational units..."
    root_id=$(aws organizations list-roots --query "Roots[0].Id" --output text --profile "$profile" 2> /dev/null)
    if [ $? -ne 0 ]; then
      handle_error 1 "Failed to fetch root ID."
    fi

    ous=$(aws organizations list-organizational-units-for-parent --parent-id "$root_id" --output "$format" --profile "$profile" 2> /dev/null)
    if [ $? -ne 0 ]; then
      handle_error 1 "Failed to fetch organizational units. Please check your permissions."
    fi
    echo "Organizational Units:"
    echo "$ous"
  fi
}

# Main script logic
main() {
  if [ $# -eq 0 ]; then
    read -p "Enter the AWS CLI profile to use: " profile
    get_organization "json" "$profile" # Default to JSON output if no arguments provided
    exit 0
  fi

  # Parse command-line options
  local profile=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -v|--version)
        show_version
        exit 0
        ;;
      -f|--format)
        format="$2"
        shift 2
        ;;
      --profile)
        profile="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
    esac
  done

  if [[ -z "$profile" ]]; then
    read -p "Enter the AWS CLI profile to use: " profile
  fi

  get_organization "${format:-json}" "$profile"
}

# Execute the main function
main "$@"
