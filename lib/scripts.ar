#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    getamiinfo
# Description:    Retrieves detailed information about a specified AWS AMI using
#                 a given AWS CLI profile.
# Usage:          getamiinfo <ami-id> <profile-name>
# Options:        -h | --help    Show this help message
# Author:         Julio Cesar Garcia 
# Date:           $(date +%Y-%m-%d)
# Version:        1.1
# ------------------------------------------------------------------------------

# Function to display help
show_help() {
  echo "Usage: getamiinfo <ami-id> <profile-name>"
  echo
  echo "Description:"
  echo "  Retrieves detailed information about the specified AMI using the"
  echo "  provided AWS CLI profile."
  echo
  echo "Options:"
  echo "  -h | --help    Show this help message"
  echo
  echo "Example:"
  echo "  getamiinfo ami-0abcdef1234567890 my-profile"
}

# Check for help option
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  show_help
  exit 0
fi

# Check if required arguments are provided
if [[ -z "$1" || -z "$2" ]]; then
  echo "ERROR: Missing required arguments."
  show_help
  exit 1
fi

AMI_ID="$1"
PROFILE_NAME="$2"

# Check if AWS CLI is installed
if ! command -v aws &> /dev/null; then
  echo "ERROR: AWS CLI is not installed. Please install it and try again."
  exit 1
fi

# Validate the provided AWS CLI profile
if ! aws sts get-caller-identity --profile "$PROFILE_NAME" > /dev/null 2>&1; then
  echo "ERROR: AWS CLI is not configured properly for profile: $PROFILE_NAME."
  echo "Please check your AWS credentials and configuration for this profile."
  exit 1
fi

# Retrieve information about the specified AMI
echo "Retrieving information for AMI: $AMI_ID"
echo "-----------------------------------------"

AMI_INFO=$(aws ec2 describe-images --image-ids "$AMI_ID" --profile "$PROFILE_NAME" --output table 2>&1)

# Check if the AMI retrieval command succeeded
if [[ $? -ne 0 ]]; then
  echo "ERROR: Failed to retrieve information for AMI: $AMI_ID"
  echo "Details: $AMI_INFO"
  exit 1
fi

# Display the retrieved information
echo "$AMI_INFO"
echo "-----------------------------------------"
echo "AMI information retrieval complete."

exit 0

