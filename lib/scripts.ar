#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    edit
# Description:    Edits an existing script or creates a new one with a default template.
# Usage:          edit [script_name]
# Options:        -h | --help    Show this help message
#                 -v | --version Show script version
# Author:         Julio Cesar Garcia
# Date:           05/03/2025
# Version:        2.5
# ------------------------------------------------------------------------------

# Default configuration file path
CONFIG_FILE="$HOME/scripts/.jcscripts"

# Load configurations from .jcscripts
if [[ -f "$CONFIG_FILE" ]]; then
  source "$CONFIG_FILE"

  # Expand `~` to `$HOME` in SCRIPTS_DIR if needed
  SCRIPTS_DIR="${SCRIPTS_DIR/#\~/$HOME}"
else
  echo "Warning: Configuration file '$CONFIG_FILE' not found. Using default settings."
  SCRIPTS_DIR="$HOME/scripts"
fi

# Use the editor specified in .jcscripts or fallback to vi
DEFAULT_EDITOR="vi"
EDITOR="${EDITOR:-$DEFAULT_EDITOR}"

# Display usage information
show_help() {
  echo "Usage: edit [script_name]"
  echo "Options:"
  echo "  -h | --help    Show this help message"
  echo "  -v | --version Show script version"
  echo
  echo "Description:"
  echo "  Creates or edits a script in the $SCRIPTS_DIR directory with a default"
  echo "  template if the script does not exist. Prevents conflicts with shell built-ins or system commands only when creating new scripts."
}

# Display script version
show_version() {
  echo "edit version 2.5"
}

# Function to handle errors
handle_error() {
  local message="$1"
  echo "Error: $message"
  exit 1
}

# Validate script name for creation
validate_script_name() {
  local script_name="$1"
  local script_path="$SCRIPTS_DIR/$script_name"

  # Skip validation for existing scripts
  if [[ -f "$script_path" ]]; then
    return 0
  fi

  # Check if the script name is empty or contains invalid characters
  if [[ -z "$script_name" || "$script_name" =~ [^a-zA-Z0-9._-] ]]; then
    handle_error "Invalid script name: $script_name. Please use only letters, numbers, dots, underscores, or hyphens."
  fi

  # Check if the name conflicts with a shell built-in or system command
  if type "$script_name" &> /dev/null; then
    handle_error "Script name '$script_name' conflicts with an existing shell built-in or system command. Please choose another name."
  fi
}

# Function to create a new script with a default template
create_new_script() {
  local script_name="$1"
  local script_path="$2"

  echo "Creating a new script: $script_name..."
  cat <<EOL > "$script_path"
#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    $script_name
# Description:    Add your description here.
# Usage:          Add your usage here.
# Author:         $LOGNAME
# Date:           $(date +%d/%m/%Y)
# Version:        1.0
# ------------------------------------------------------------------------------

# Display usage information
show_help() {
  echo "Usage: ./$script_name [options]"
  echo "Options:"
  echo "  -h | --help    Show this help message"
  echo "  -v | --version Show script version"
}

# Display script version
show_version() {
  echo "$script_name version 1.0"
}

# Main script logic
main() {
  echo "Welcome to $0!"
  echo "Add your code logic here."
}

# Execute the main function
main "\$@"

EOL

  chmod +x "$script_path"
  echo "New script created at: $script_path"
}

# Main function
main() {
  # Check if no arguments were provided
  if [[ $# -eq 0 ]]; then
    show_help
    exit 1
  fi

  case "$1" in
    -h|--help)
      show_help
      exit 0
      ;;
    -v|--version)
      show_version
      exit 0
      ;;
    *)
      # Define script name and path
      local script_name="$1"
      local script_path="$SCRIPTS_DIR/$script_name"

      # Ensure target directory exists
      mkdir -p "$SCRIPTS_DIR"

      # If the script exists, open it for editing
      if [[ -f "$script_path" ]]; then
        echo "Opening existing script with $EDITOR: $script_path"
        $EDITOR "$script_path"
        exit 0
      fi

      # Validate the name only for creating a new script
      validate_script_name "$script_name"

      # Create the script if it doesn't exist
      create_new_script "$script_name" "$script_path"

      # Open the new script with the specified editor
      echo "Opening script with $EDITOR: $script_path"
      $EDITOR "$script_path"
      ;;
  esac
}

# Execute the main function
main "$@"

