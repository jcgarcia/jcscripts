#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    createscripts
# Description:    Initializes a Git repository for scripts, commits them, and
#                 pushes to a remote GitHub repository.
# Usage:          createscripts <repository-name>
# Options:        -h | --help    Show this help message
# Author:         Julio Cesar Garcia
# Date:           20/03/2025 
# Version:        1.1
# ------------------------------------------------------------------------------

# Function to display help
show_help() {
  echo "Usage: createscripts <repository-name>"
  echo "Description:"
  echo "  Initializes a Git repository for scripts, commits them, and pushes"
  echo "  to a remote GitHub repository."
  echo
  echo "Options:"
  echo "  -h | --help    Show this help message"
  echo
  echo "Example:"
  echo "  createscripts my-scripts-repo"
}

# Check for help option
if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  show_help
  exit 0
fi

# Check if a repository name is provided
if [ -z "$1" ]; then
  echo "ERROR: No repository name provided."
  show_help
  exit 1
fi

REPO_NAME=$1

# Prompt for GitHub username and email
read -p "Enter your GitHub username: " USERNAME
read -p "Enter your GitHub email: " EMAIL

# Validate inputs
if [[ -z "$USERNAME" || -z "$EMAIL" ]]; then
  echo "ERROR: Both username and email must be provided. Exiting."
  exit 1
fi

# Configure Git
echo "Configuring Git..."
git config --global user.name "$USERNAME"
git config --global user.email "$EMAIL"

# Navigate to the scripts directory
if [ ! -d "$HOME/scripts" ]; then
  echo "ERROR: The ~/scripts directory does not exist. Please ensure your scripts are located there."
  exit 1
fi

cd ~/scripts

# Initialize a Git repository
if [ ! -d ".git" ]; then
  echo "Initializing Git repository..."
  git init
else
  echo "Git repository already initialized."
fi

# Add scripts to the repository
echo "Adding scripts to the repository..."
git add .

# Commit the changes
echo "Committing changes..."
git commit -m "Initial commit of scripts"

# Add the remote repository
REMOTE_URL="https://github.com/$USERNAME/$REPO_NAME.git"
git remote add origin "$REMOTE_URL" || {
  echo "Remote repository already exists. Skipping 'git remote add'."
}

# Push to the remote repository
echo "Pushing scripts to GitHub..."
git push -u origin master || {
  echo "ERROR: Failed to push to GitHub. Please check your repository settings and authentication."
  exit 1
}

echo "✅ Scripts successfully pushed to GitHub repository: $REPO_NAME"
