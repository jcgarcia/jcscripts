#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    createOrgAdm
# Description:    Creates an Organization Administrator user and permission set
#                 for AWS SSO with the specified profile and region.
# Usage:          createOrgAdm [-p|--profile PROFILE] [-e|--email EMAIL] [-r|--region REGION]
# Options:        -h | --help       Show this help message
#                 -v | --version    Show script version
#                 -p | --profile    AWS CLI profile to use
#                 -e | --email      OrgAdm user email address
#                 -r | --region     AWS region (default: us-east-1)
# Author:         Julio Cesar Garcia
# Date:           20/03/2025
# Version:        1.2
# ------------------------------------------------------------------------------

set -e  # Exit immediately if a command exits with a non-zero status

# Default values
AWS_REGION="eu-west-2"
LOG_FILE="createOrgAdm.log"

# Display usage information
show_help() {
  echo "Usage: createOrgAdm [options]"
  echo "Options:"
  echo "  -h | --help       Show this help message"
  echo "  -v | --version    Show script version"
  echo "  -p | --profile    AWS CLI profile to use"
  echo "  -e | --email      OrgAdm user email address"
  echo "  -r | --region     AWS region (default: $AWS_REGION)"
  echo
  echo "Example:"
  echo "  createOrgAdm -p MyProfile -e orgadm@example.com -r us-west-2"
}

# Display script version
show_version() {
  echo "createOrgAdm version 1.2"
}

# Error handling function
handle_error() {
  local exit_code=$1
  local message=$2
  echo "Error: $message (Exit Code: $exit_code)"
  exit $exit_code
}

# Function to validate the AWS session
validate_session() {
  local profile="$1"

  if [[ -z "$profile" ]]; then
    handle_error 1 "AWS profile is not provided. Please specify a profile."
  fi

  # Check if AWS CLI is installed
  if ! command -v aws &> /dev/null; then
    handle_error 1 "AWS CLI is not installed. Please install it and try again."
  fi

  # Validate the AWS CLI profile
  if ! aws sts get-caller-identity --profile "$profile" > /dev/null 2>&1; then
    handle_error 1 "AWS CLI session is not valid or the profile is misconfigured: $profile."
    echo "Please log in using 'aws sso login --profile $profile' and try again."
    exit 1
  fi
}

# Main function
main() {
  # Parse command-line arguments
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -v|--version)
        show_version
        exit 0
        ;;
      -p|--profile)
        AWS_PROFILE="$2"
        shift 2
        ;;
      -e|--email)
        ORGADM_EMAIL="$2"
        shift 2
        ;;
      -r|--region)
        AWS_REGION="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
    esac
  done

  # Validate required parameters
  if [[ -z "$AWS_PROFILE" ]]; then
    handle_error 1 "AWS CLI profile is required. Use the -p option."
  fi

  if [[ -z "$ORGADM_EMAIL" ]]; then
    handle_error 1 "OrgAdm user email is required. Use the -e option."
  fi

  # Validate AWS session
  validate_session "$AWS_PROFILE"

  # Log in to AWS SSO
  echo "[$(date)] Logging in to AWS SSO with profile: $AWS_PROFILE..." | tee -a "$LOG_FILE"
  aws sso login --profile "$AWS_PROFILE"

  # AWS SSO Instance ARN
  SSO_INSTANCE_ARN=$(aws sso-admin list-instances --query "Instances[0].InstanceArn" --output text --region "$AWS_REGION" --profile "$AWS_PROFILE")
  echo "[$(date)] SSO Instance ARN: $SSO_INSTANCE_ARN" | tee -a "$LOG_FILE"

  # Management Account ID
  MANAGEMENT_ACCOUNT_ID=$(aws organizations describe-organization --query "Organization.MasterAccountId" --output text --region "$AWS_REGION" --profile "$AWS_PROFILE")
  echo "[$(date)] Management Account ID: $MANAGEMENT_ACCOUNT_ID" | tee -a "$LOG_FILE"

  echo "[$(date)] Creating OrganizationAdministration permission set..." | tee -a "$LOG_FILE"

  # Create the Permission Set
  PERMISSION_SET_ARN=$(aws sso-admin create-permission-set \
    --instance-arn "$SSO_INSTANCE_ARN" \
    --name "OrganizationAdministration" \
    --description "Permission set for Organization Administration" \
    --session-duration "PT4H" \
    --query "PermissionSet.PermissionSetArn" --output text --region "$AWS_REGION" --profile "$AWS_PROFILE")
  echo "[$(date)] Permission Set ARN: $PERMISSION_SET_ARN" | tee -a "$LOG_FILE"

  # Attach AWS Managed Policies
  echo "[$(date)] Attaching managed policies..." | tee -a "$LOG_FILE"
  for policy in "arn:aws:iam::aws:policy/AdministratorAccess" \
                "arn:aws:iam::aws:policy/AWSOrganizationsFullAccess" \
                "arn:aws:iam::aws:policy/IAMFullAccess"; do
    aws sso-admin attach-managed-policy-to-permission-set \
      --instance-arn "$SSO_INSTANCE_ARN" \
      --permission-set-arn "$PERMISSION_SET_ARN" \
      --managed-policy-arn "$policy" --region "$AWS_REGION" --profile "$AWS_PROFILE"
  done

  # Provision the Permission Set
  echo "[$(date)] Provisioning the permission set..." | tee -a "$LOG_FILE"
  aws sso-admin provision-permission-set \
    --instance-arn "$SSO_INSTANCE_ARN" \
    --permission-set-arn "$PERMISSION_SET_ARN" --region "$AWS_REGION" --profile "$AWS_PROFILE"

  # Retrieve Identity Store ID
  IDENTITY_STORE_ID=$(aws sso-admin list-instances --query "Instances[0].IdentityStoreId" --output text --region "$AWS_REGION" --profile "$AWS_PROFILE")
  echo "[$(date)] Identity Store ID: $IDENTITY_STORE_ID" | tee -a "$LOG_FILE"

  # Create the OrgAdm User
  echo "[$(date)] Creating OrgAdm user with email: $ORGADM_EMAIL..." | tee -a "$LOG_FILE"
  ORGADM_USER_ID=$(aws identitystore create-user \
    --identity-store-id "$IDENTITY_STORE_ID" \
    --user-name "OrgAdm" \
    --display-name "Organization Administrator" \
    --emails "[{\"Value\":\"$ORGADM_EMAIL\",\"Type\":\"work\"}]" \
    --query "UserId" --output text --region "$AWS_REGION" --profile "$AWS_PROFILE")

  # Assign the OrgAdm user to the Management Account
  echo "[$(date)] Assigning OrgAdm user to Management Account..." | tee -a "$LOG_FILE"
  aws sso-admin create-account-assignment \
    --instance-arn "$SSO_INSTANCE_ARN" \
    --target-id "$MANAGEMENT_ACCOUNT_ID" \
    --target-type "AWS_ACCOUNT" \
    --permission-set-arn "$PERMISSION_SET_ARN" \
    --principal-type "USER" \
    --principal-id "$ORGADM_USER_ID" --region "$AWS_REGION" --profile "$AWS_PROFILE"

  echo "[$(date)] OrgAdm user and OrganizationAdministration permission set successfully created and assigned!" | tee -a "$LOG_FILE"
}

# Execute the main function
main "$@"

