#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    awsres
# Description:    Retrieve and display AWS resource information.
# Usage:          awsres [-h|--help] [-v|--version] [-r|--resources] [-2|--r2]
# Options:        -h | --help        Show this help message
#                 -v | --version     Show script version
#                 -r | --resources   Fetch and display AWS resources
# Author:         Julio Cesar Garcia
# Date:           28/02/2025
# Version:        2.1
# ------------------------------------------------------------------------------

# Display usage information
show_help() {
  echo "Usage: ./awsres [options]"
  echo "Options:"
  echo "  -h | --help        Show this help message"
  echo "  -v | --version     Show script version"
  echo "  -r | --resources   Fetch and display AWS resources"
  echo "  -2 | --r2          Fetch an extended list of AWS resources"
}

# Display script version
show_version() {
  echo "awsres version 2.1"
}

# Error handling function
handle_error() {
  local exit_code=$1
  local message=$2
  echo "Error: $message (Exit Code: $exit_code)"
  exit $exit_code
}

# Function to validate the AWS session
validate_session() {
  local profile="$1"

  if [[ -z "$profile" ]]; then
    handle_error 1 "AWS profile is not provided. Please specify a profile."
  fi

  # Check if AWS CLI is installed
  if ! command -v aws &> /dev/null; then
    handle_error 1 "AWS CLI is not installed. Please install it and try again."
  fi

  # Validate the AWS CLI profile
  if ! aws sts get-caller-identity --profile "$profile" > /dev/null 2>&1; then
    handle_error 1 "AWS CLI session is not valid or the profile is misconfigured: $profile."
    echo "Please log in using 'aws sso login --profile $profile' and try again."
    exit 1
  fi
}

# Function to fetch a detailed list of AWS resources (basic version)
aws_resources() {
  local profile="$1"
  validate_session "$profile"

  echo "Retrieving information about AWS resources and their statuses..."
  echo "This may take a moment..."

  # Fetch a list of all tagged resources
  resources=$(aws resourcegroupstaggingapi get-resources --profile "$profile" --output json)
  
  if [ $? -ne 0 ]; then
    handle_error 1 "Failed to retrieve resources. Please check your AWS permissions."
  fi

  echo "Resources and their statuses:"
  echo "$resources" | jq '.ResourceTagMappingList[] | {ResourceARN: .ResourceARN, Tags: .Tags}'
}

# Function to fetch an extended list of AWS resources
aws_resources2() {
  local profile="$1"
  validate_session "$profile"

  echo "Fetching detailed AWS resources..."
  echo "-----------------------------------------------"

  # List EC2 instances
  echo "EC2 Instances:"
  aws ec2 describe-instances --profile "$profile" --query 'Reservations[*].Instances[*].[InstanceId,InstanceType,State.Name,PublicIpAddress]' --output table
  echo "-----------------------------------------------"

  # List S3 buckets
  echo "S3 Buckets:"
  aws s3 ls --profile "$profile"
  echo "-----------------------------------------------"

  # List RDS instances
  echo "RDS Instances:"
  aws rds describe-db-instances --profile "$profile" --query 'DBInstances[*].[DBInstanceIdentifier,DBInstanceClass,Engine,DBInstanceStatus]' --output table
  echo "-----------------------------------------------"

  # List Lambda functions
  echo "Lambda Functions:"
  aws lambda list-functions --profile "$profile" --query 'Functions[*].[FunctionName,Runtime,LastModified]' --output table
  echo "-----------------------------------------------"

  # List ECS clusters
  echo "ECS Clusters:"
  aws ecs list-clusters --profile "$profile" --query 'clusterArns' --output table
  echo "-----------------------------------------------"

  # List EKS clusters
  echo "EKS Clusters:"
  aws eks list-clusters --profile "$profile" --query 'clusters' --output table
  echo "-----------------------------------------------"

  # List CloudFormation stacks
  echo "CloudFormation Stacks:"
  aws cloudformation list-stacks --profile "$profile" --query 'StackSummaries[*].[StackName,StackStatus,CreationTime]' --output table
  echo "-----------------------------------------------"

  # List IAM roles
  echo "IAM Roles:"
  aws iam list-roles --profile "$profile" --query 'Roles[*].[RoleName,Arn]' --output table
  echo "-----------------------------------------------"

  # List DynamoDB tables
  echo "DynamoDB Tables:"
  aws dynamodb list-tables --profile "$profile" --query 'TableNames' --output table
  echo "-----------------------------------------------"

  # List SQS queues
  echo "SQS Queues:"
  aws sqs list-queues --profile "$profile" --query 'QueueUrls' --output table
  echo "-----------------------------------------------"

  # List SNS topics
  echo "SNS Topics:"
  aws sns list-topics --profile "$profile" --query 'Topics[*].[TopicArn]' --output table
  echo "-----------------------------------------------"

  echo "Resource check complete."
}

# Main script logic
main() {
  local profile=""
  read -p "Enter the AWS CLI profile to use: " profile

  # Check if no arguments were provided
  if [ $# -eq 0 ]; then
    aws_resources "$profile"
    exit 0
  fi

  # Parse command-line options
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -v|--version)
        show_version
        exit 0
        ;;
      -r|--resources)
        aws_resources "$profile"
        exit 0
        ;;
      -2|--r2)
        aws_resources2 "$profile"
        exit 0
        ;;
      *)
        echo "Unknown option: $1"
        show_help
        exit 1
        ;;
    esac
    shift
  done
}

# Execute the main function
main "$@"

