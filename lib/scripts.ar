#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    backup
# Description:    Backup WSL distributions to an external location.
# Usage:          backup [options]
# Options:
#                 -h | --help       Show this help message
#                 -v | --version    Show script version
#                 --list            List all WSL distributions
#                 -d | --distro     Specify the distribution to back up
#                 -l | --location   Specify the backup location
# Author:         Julio Cesar Garcia
# Date:           2025-03-21
# Version:        6.1
# ------------------------------------------------------------------------------

# Default backup directory
DEFAULT_BACKUP_DIR="/mnt/c/backup/wsl"

# Display script version
show_version() {
  echo "backup version 6.1"
}

# List WSL distributions
list_distributions() {
  echo "Processing and cleaning the distribution list..."

  /mnt/c/Windows/System32/wsl.exe --list \
    | sed '1d' \
    | sed 's/ (Default)//g' \
    | tr -cd '\11\12\15\40-\176' \
    | sed '/^$/d' \
    | awk '{$1=$1; print}'
}

# Validate distribution existence
validate_distro() {
  local distro="$1"

  # Fetch sanitized list
  local distro_list
  distro_list=$(list_distributions)

  # Ensure the list is not empty
  if [[ -z "$distro_list" ]]; then
    echo "ERROR: Failed to retrieve a valid distribution list."
    exit 1
  fi

  # Strip (Default) from the list
  distro_list=${distro_list// \(Default\)/}

  # Compare sanitized distro input with each line
  while IFS= read -r line; do
    line=$(echo "$line" | tr -d '\r\n') # Sanitize line
    if [[ "$line" == "$distro" ]]; then
      return 0
    fi
  done <<< "$distro_list"

  echo "ERROR: Distribution '$distro' not found."
  exit 1
}

# Get the currently running distribution using $WSL_DISTRO_NAME
get_active_distro() {
  if [[ -n "$WSL_DISTRO_NAME" ]]; then
    echo "$WSL_DISTRO_NAME"
  else
    echo "ERROR: Unable to detect active distribution. WSL_DISTRO_NAME is not set."
    exit 1
  fi
}

# Main script logic
main() {
  local distro=""
  local backup_dir="$DEFAULT_BACKUP_DIR"

  # Parse options
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        show_help
        exit 0
        ;;
      -v|--version)
        show_version
        exit 0
        ;;
      --list)
        list_distributions
        exit 0
        ;;
      -d|--distro)
        distro="$2"
        shift 2
        ;;
      -l|--location)
        backup_dir="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  if [[ -z "$distro" ]]; then
    echo "ERROR: No distribution specified."
    exit 1
  fi

  validate_distro "$distro"

  # Detect if the user is trying to back up the currently active distribution
  local active_distro
  active_distro=$(get_active_distro)

  if [[ "$distro" == "$active_distro" ]]; then
    echo "WARNING: You are attempting to back up the active distribution ('$active_distro')."
    echo "This operation may cause the terminal session to close unexpectedly."
    read -p "Do you wish to continue? (yes/no): " user_choice
    if [[ "$user_choice" != "yes" ]]; then
      echo "Backup operation canceled by user."
      exit 1
    fi
  fi

  # Ensure backup directory exists
  mkdir -p "$backup_dir"

  # Define backup file name
  local backup_file="C:\\backup\\wsl\\${distro}_backup_$(date +"%Y-%m-%d_%H-%M-%S").tar"

  # Perform the actual backup using PowerShell
  echo "Starting backup for '$distro' using PowerShell..."
  powershell.exe -Command "wsl.exe --export \"$distro\" \"$backup_file\"" || {
    echo "ERROR: Failed to export distribution '$distro'."
    exit 1
  }

  echo "Backup completed successfully: $backup_file"
}

# Execute script
main "$@"connecttoaws/   0           0     0     644     2535      `
#!/bin/bash

# ------------------------------------------------------------------------------
# Script Name:    connecttoaws
# Description:    Logs into AWS SSO with the specified profile and optionally
#                 executes AWS CLI commands using that profile.
# Usage:          connecttoaws <profile-name> [<aws-command>]
# Options:        -h | --help    Show this help message
# Author:         Julio Cesar Garcia
# Date:           20/03/2025
# Version:        1.1
# ------------------------------------------------------------------------------

# Display usage information
show_help() {
  echo "Usage: $0 <profile-name> [<aws-command>]"
  echo "Options:"
  echo "  -h | --help    Show this help message"
  echo "Example:"
  echo "  $0 my-profile"
  echo "  $0 my-profile 'aws s3 ls'"
}

# Check if AWS CLI is installed
check_aws_cli() {
  if ! command -v aws &> /dev/null; then
    echo "ERROR: AWS CLI is not installed. Please install it and try again."
    exit 1
  fi
}

# Validate the AWS profile
validate_profile() {
  local profile="$1"
  if ! aws configure list-profiles | grep -q "^$profile$"; then
    echo "ERROR: AWS profile '$profile' not found. Please check your configuration."
    exit 1
  fi
}

# Main function
main() {
  # Show help if no arguments are provided or -h/--help is passed
  if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    show_help
    exit 0
  fi

  # Extract the profile name
  PROFILE_NAME="$1"
  shift # Remove the profile name from arguments

  # Check for AWS CLI and validate profile
  check_aws_cli
  validate_profile "$PROFILE_NAME"

  # Login to AWS SSO using the provided profile name
  echo "Attempting to login with profile: $PROFILE_NAME"
  aws sso login --profile "$PROFILE_NAME"
  if [[ $? -ne 0 ]]; then
    echo "ERROR: Failed to log in to AWS SSO with profile: $PROFILE_NAME"
    exit 1
  fi
  echo "SUCCESS: Logged in to AWS SSO with profile: $PROFILE_NAME"

  # Execute the optional AWS command if provided
  if [[ $# -gt 0 ]]; then
    echo "Executing AWS command with profile '$PROFILE_NAME': $@"
    AWS_PROFILE="$PROFILE_NAME" "$@"
    if [[ $? -ne 0 ]]; then
      echo "ERROR: AWS command failed."
      exit 1
    fi
  else
    # Default behavior: List S3 buckets
    echo "Listing S3 buckets with profile '$PROFILE_NAME'..."
    aws s3 ls --profile "$PROFILE_NAME"
    if [[ $? -ne 0 ]]; then
      echo "ERROR: Failed to list S3 buckets with profile: $PROFILE_NAME"
      exit 1
    fi
  fi

  echo "Done."
}

# Execute the main function
main "$@"


